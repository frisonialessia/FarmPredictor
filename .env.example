# FarmPredictor — environment variables. Copy to .env.local and fill as needed.
# Everything is OPTIONAL: with none of these set the app runs fully offline and
# free (simulated data, real weather via Open-Meteo, free assistant mock).

# Enables real AI answers in the "Ask your farm" assistant.
# Unset → a free, deterministic mock answer is used instead.
ANTHROPIC_API_KEY=

# Absolute site URL for Open Graph images and the sitemap (e.g. https://farmpredictor.app).
NEXT_PUBLIC_SITE_URL=

# Phase 3 — the Python + OR-Tools optimizer microservice (see optimizer/).
# Unset → the app uses its built-in TypeScript scheduling heuristic (today).
# Set to the deployed service URL to turn on optimal scheduling, e.g.
#   NEXT_PUBLIC_OPTIMIZER_URL=https://farmpredictor-optimizer.fly.dev
NEXT_PUBLIC_OPTIMIZER_URL=

# Observability (error reporting). Unset → errors are logged locally only.
# Set to a Sentry DSN to forward errors once the sink is wired in lib/observability.ts.
NEXT_PUBLIC_SENTRY_DSN=

# Phase 2 — Supabase (designed in supabase/, not yet connected).
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
